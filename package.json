{
	"name": "yank-cli",
	"version": "1.4.1",
	"description": "CLI to print, format, and copy source code.",
	"keywords": [
		"cli",
		"clipboard",
		"context",
		"copy",
		"developer-tools",
		"llm-context",
		"paste",
		"source-code"
	],
	"homepage": "https://github.com/gorango/yank",
	"bugs": "https://github.com/gorango/yank/issues",
	"license": "MIT",
	"author": "gorango",
	"repository": {
		"type": "git",
		"url": "https://github.com/gorango/yank.git"
	},
	"bin": {
		"yank": "dist/main.mjs"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"lint": "oxlint --fix && oxfmt",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@inquirer/prompts": "^8.4.2",
		"byte-size": "^9.0.1",
		"cac": "^7.0.0",
		"clipboardy": "^5.3.1",
		"cosmiconfig": "^9.0.1",
		"cosmiconfig-toml-loader": "^1.0.0",
		"fast-glob": "^3.3.3",
		"ignore": "^7.0.5"
	},
	"devDependencies": {
		"@types/byte-size": "^8.1.2",
		"@types/node": "^25.6.0",
		"@types/yargs": "^17.0.35",
		"@vitest/coverage-v8": "^4.1.4",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"tsdown": "^0.21.9",
		"typescript": "^6.0.3",
		"vitest": "^4.1.4",
		"yaml": "^2.8.3"
	}
}
